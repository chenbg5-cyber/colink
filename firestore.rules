rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /families/{familyCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == memberId;
      }

      match /sharedData/{docId} {
        allow read, write: if request.auth != null &&
          exists(/databases/$(database)/documents/families/$(familyCode)/members/$(request.auth.uid));
      }

      match /notifications/{docId} {
        allow read, write: if request.auth != null &&
          exists(/databases/$(database)/documents/families/$(familyCode)/members/$(request.auth.uid));
      }

      match /pushTokens/{tokenId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/families/$(familyCode)/members/$(request.auth.uid));
        allow write: if request.auth != null && request.auth.uid == tokenId;
      }
    }
  }
}
